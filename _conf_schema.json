{
    "llm_api_key": {
        "description": "API Key",
        "type": "string",
        "hint": "大模型 API 密钥",
        "obvious_hint": true,
        "default": ""
    },
    "llm_base_url": {
        "description": "API Base URL",
        "type": "string",
        "hint": "接口地址，例如 https://api.deepseek.com/v1",
        "default": "https://api.deepseek.com/v1"
    },
    "llm_model": {
        "description": "文本对话模型",
        "type": "string",
        "hint": "处理普通聊天，例如 deepseek-chat",
        "default": "deepseek-chat"
    },
    "llm_vision_model": {
        "description": "多模态(视觉)模型",
        "type": "string",
        "hint": "处理图片解析，需填支持 Vision 的模型，例如 gpt-4o 或 qwen-vl-max",
        "default": "qwen-vl-max"
    },
    "delay_between_chat": {
        "description": "消息发送时延",
        "type": "float",
        "hint": "模拟真人打字速度",
        "default": 1.5
    }
}